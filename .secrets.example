# ===========================================
# Environment Variables — Secrets & Configuration
# ===========================================
# Copy this file to ~/.config/dotfiles/.secrets and fill in real values.
# This file is checked into git as a reference template.
# The actual ~/.config/dotfiles/.secrets is gitignored and NEVER committed.

# ------------------------------------
# Dotfiles
# ------------------------------------

# Absolute path to the dotfiles repository
DOTFILES_DIR="$HOME/path/to/my-dot-files"

# ------------------------------------
# Git Identity (default)
# ------------------------------------

GIT_USER_NAME="Your Name"
GIT_USER_EMAIL="your@email.com"

# ------------------------------------
# Navigation Paths
# ------------------------------------

# Obsidian vault location (used by cd-to-obsidian alias)
OBSIDIAN_VAULT_PATH="$HOME/Documents/Obsidian"

# ------------------------------------
# Projects
# ------------------------------------
# Each project generates aliases: <name>-app, <name>-api, <name>-test,
# <name>-e2e, <name>-reinstall. See shell/templates/project.sh.tpl.
#
# Optional: PROJECT_<N>_DIR + PROJECT_<N>_GIT_EMAIL override the default
# git email for all repositories under that directory (via git includeIf).

# PROJECT_1_NAME=myapp
# PROJECT_1_DIR="$HOME/projects/myapp"
# PROJECT_1_GIT_EMAIL="work@company.com"
# PROJECT_1_APP="nx serve app"
# PROJECT_1_API="nx serve api"
# PROJECT_1_TEST="yarn nx affected --target=test --maxParallel=2"
# PROJECT_1_E2E="yarn nx e2e app-e2e --watch"
# PROJECT_1_REINSTALL="find . -name node_modules -type d -prune -exec rm -rf {} + && yarn"
# PROJECT_1_WT_REPO="$HOME/projects/myapp"
# PROJECT_1_WT_BRANCH=main
# PROJECT_1_WT_ENV_FILES=".env apps/app/.env apps/api/.env"
# PROJECT_1_WT_INSTALL="pnpm install"

# PROJECT_2_NAME=sideproject
# PROJECT_2_DIR="$HOME/projects/side"
# PROJECT_2_GIT_EMAIL="personal@gmail.com"
# PROJECT_2_APP="npm run dev"
# PROJECT_2_API="npm run api"
# PROJECT_2_TEST="npm test"
# PROJECT_2_E2E="npm run e2e"
# PROJECT_2_REINSTALL="rm -rf node_modules && npm install"
# PROJECT_2_WT_REPO="$HOME/projects/side/repo"
# PROJECT_2_WT_BRANCH=main
# PROJECT_2_WT_ENV_FILES=".env"
# PROJECT_2_WT_INSTALL="npm install"

# ------------------------------------
# Claude Code — Work Accounts
# ------------------------------------
# Each account generates a claude-<name> shell function.
# See shell/templates/claude-account.sh.tpl.

# CLAUDE_ACCOUNT_1_NAME=work
# CLAUDE_ACCOUNT_1_USE_VERTEX=true
# CLAUDE_ACCOUNT_1_REGION=global
# CLAUDE_ACCOUNT_1_PROJECT_ID=my-gcp-project
# CLAUDE_ACCOUNT_1_CONFIG_DIR=$HOME/.claude-work
# CLAUDE_ACCOUNT_1_EXTRA_VARS="MY_API_TOKEN=$MY_SECRET"

# ------------------------------------
# VPN (OpenVPN)
# ------------------------------------

# Path to .ovpn profile file
# VPN_CONFIG_PATH="$HOME/path/to/profile.ovpn"

# Path to openvpn binary (auto-detected if not set)
# VPN_OPENVPN_BIN="/opt/homebrew/opt/openvpn/sbin/openvpn"
